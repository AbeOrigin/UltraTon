{
  "name": "ultraton",
  "version": "1.0.3",
  "type": "module",
  "description": "Ultra safe HTTP client for critical environments in Node.js",
  "homepage":"https://abeorigin.github.io/UltraTon/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbeOrigin/UltraTon.git"
  },
  "bugs": {
    "url": "https://github.com/AbeOrigin/UltraTon/issues"
  },
  "main": "./dist/http-client.js",
  "types": "./dist/http-client.d.ts",
  "exports": {
    ".": {
      "import": "./dist/http-client.js",
      "types": "./dist/http-client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:strict": "tsc --noEmit --strict",
    "test": "node --experimental-strip-types --test __tests__/**/*.test.ts",
    "prepublishOnly": "npm run test && npm run build",
    "demo:http2:server": "node --experimental-strip-types demo/http2.server.ts",
    "demo:http2:client": "node --experimental-strip-types demo/http2.client.ts",
    "demo:server": "node --experimental-strip-types demo/server.ts",
    "demo:client": "node --experimental-strip-types demo/client.ts"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}